---
export const prerender = true;

import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import QuestionList from '../components/QuestionList';

const markdown = readFileSync(join(process.cwd(), 'public', 'Perguntas-Fundamentais.md'), 'utf-8');

const sections = markdown.split('---').filter(s => s.trim());

interface Question {
  id: number;
  pergunta: string;
  resposta: string;
  dicas: string;
  referencia: string;
}

const questions: Question[] = [];

for (const section of sections) {
  const camposMatch = section.match(/\*\*Pergunta\*\*\s*\|\s*(.+?)\n\*\*Resposta\*\*\s*\|\s*(.+?)\n\*\*Dicas\*\*\s*\|\s*(.+?)\n\*\*Referência\*\*\s*\|\s*(.+)/s);

  if (!camposMatch) continue;

  const [, pergunta, resposta, dicas, referencia] = camposMatch;

  questions.push({
    id: questions.length + 1,
    pergunta: pergunta.trim(),
    resposta: resposta.trim(),
    dicas: dicas.trim(),
    referencia: referencia.trim()
  });
}
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Perguntas de Defesa — Sistema de Gestão para Ginásio</title>
  <style>
    :root {
      --bg: #0f0f0f;
      --bg-card: #1a1a1a;
      --bg-hover: #252525;
      --border: #333;
      --text: #e0e0e0;
      --text-muted: #888;
      --accent: #646cff;
      --accent-hover: #7c7fff;
      --success: #4ade80;
      --warning: #fbbf24;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    header {
      text-align: center;
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .header-meta {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .subtitle {
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    .stats {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 1.5rem;
    }

    .stat-card {
      background: var(--bg-card);
      padding: 1rem 1.5rem;
      border-radius: 8px;
      border: 1px solid var(--border);
    }

    .stat-card .value {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent);
    }

    .stat-card .label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    .question-item {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 1rem;
      overflow: hidden;
    }

    .question-header {
      padding: 1rem 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }

    .question-number {
      background: var(--accent);
      color: white;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.875rem;
      flex-shrink: 0;
    }

    .question-content {
      flex: 1;
    }

    .question-text {
      font-weight: 500;
      margin-bottom: 0.75rem;
    }

    .question-buttons {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .q-btn {
      padding: 0.375rem 0.75rem;
      border: 1px solid var(--border);
      background: var(--bg-hover);
      color: var(--text);
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.8125rem;
      transition: all 0.15s;
    }

    .q-btn:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    .q-btn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }

    .answer-content,
    .dicas-content,
    .referencia-content {
      display: none;
      padding: 1rem 1.25rem;
      padding-top: 0;
      border-top: 1px solid var(--border);
      margin-top: 0;
    }

    .answer-content.open,
    .dicas-content.open,
    .referencia-content.open {
      display: block;
    }

    .block-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
      margin-top: 1rem;
    }

    .answer-content {
      color: var(--text);
    }

    .dicas-content {
      color: var(--warning);
    }

    .referencia-content {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      margin-top: 3rem;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    footer p {
      margin: 0.25rem 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Perguntas Fundamentais</h1>
      <p class="subtitle">Sistema de Gestão para Ginásio — MSES</p>
      <p class="header-meta">Universidade de Aveiro</p>
      <div class="stats">
        <div class="stat-card">
          <div class="value">20</div>
          <div class="label">Perguntas</div>
        </div>
      </div>
    </header>

    <main id="questions">
      <QuestionList questions={questions} client:load />
    </main>

    <footer>
      <p>Derlan Nascimento · Micael Oliveira · Rodrigo Fonseca · Tiago Jacinto</p>
      <p>Orientador: Professor José Martins</p>
      <p>Sistema de Gestão para Ginásio — MSES 2024/2025</p>
    </footer>
  </div>
</body>
</html>