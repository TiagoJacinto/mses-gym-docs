---
import fs from 'node:fs';
import path from 'node:path';

const filePath = path.join(process.cwd(), 'public/Trabalho-MSES.md');
const content = fs.readFileSync(filePath, 'utf-8');

export const prerender = true;
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema de Gestão para Ginásio — MSES</title>
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/panzoom@9.4.3/dist/panzoom.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --bg: #fafafa;
      --bg-code: #1e1e1e;
      --text: #222;
      --text-muted: #666;
      --accent: #3b82f6;
      --border: #e5e5e5;
      --radius: 8px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111;
        --bg-code: #0d0d0d;
        --text: #e5e5e5;
        --text-muted: #888;
        --border: #2a2a2a;
      }
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 800;
      margin: 0 0 0.5rem;
      letter-spacing: -0.03em;
    }

    h2 {
      font-size: 1.4rem;
      font-weight: 700;
      margin: 2.5rem 0 1rem;
      letter-spacing: -0.02em;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
    }

    h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
    }

    h4 {
      font-size: 1rem;
      font-weight: 600;
      margin: 1.5rem 0 0.5rem;
    }

    p { margin: 0 0 1rem; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    strong { font-weight: 600; }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1.5rem 0;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 0.6rem 0.85rem;
      text-align: left;
    }

    th {
      background: rgba(59, 130, 246, 0.06);
      font-weight: 600;
    }

    @media (prefers-color-scheme: dark) {
      th { background: rgba(59, 130, 246, 0.1); }
    }

    code {
      font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--bg-code);
      color: #e5e5e5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
    }

    pre {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background: none;
      padding: 0;
      font-size: 0.85rem;
    }

    ul, ol {
      padding-left: 1.5rem;
      margin: 0 0 1rem;
    }

    li { margin-bottom: 0.3rem; }

    blockquote {
      border-left: 3px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1rem;
      color: var(--text-muted);
    }

    .mermaid {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin: 2rem 0;
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .mermaid svg {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      cursor: grab;
      overflow: hidden;
    }

    .mermaid svg:active { cursor: grabbing; }

    .mermaid svg > g { pointer-events: all; }

    .mermaid-pan-wrapper {
      overflow: hidden;
      position: relative;
    }

    #table-of-contents {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
    }

    #table-of-contents summary {
      font-weight: 700;
      cursor: pointer;
      margin-bottom: 0.5rem;
      color: var(--text-muted);
      list-style: none;
    }

    #table-of-contents summary::-webkit-details-marker { display: none; }

    #table-of-contents ul {
      list-style: none;
      padding-left: 0;
      margin: 0;
    }

    #table-of-contents li { margin-bottom: 0.25rem; }
    #table-of-contents a { color: var(--text); }
    #table-of-contents a:hover { color: var(--accent); }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Sistema de Gestão para Ginásio</h1>
      <p style="color:var(--text-muted); margin:0">Modelação de Sistemas e Engenharia de Software — Universidade de Aveiro</p>
    </header>

    <details id="table-of-contents" open>
      <summary>Índice</summary>
      <ul></ul>
    </details>

    <article id="content"></article>
  </div>

  <script is:inline define:vars={{ content }}>
    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function parseMarkdown(md) {
      let html = md;

      // mermaid code blocks - extract before processing
      const mermaidBlocks = [];
      html = html.replace(/```mermaid\n([\s\S]*?)```/g, (_, code) => {
        mermaidBlocks.push(code.trim());
        return `%%MERMAID_${mermaidBlocks.length - 1}%%`;
      });

      // regular code blocks
      html = html.replace(/```(\w+)?\n([\s\S]*?)```/g, (_, lang, code) =>
        `<pre><code class="language-${lang || ''}">${escapeHtml(code)}</code></pre>`);

      // inline code
      html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

      // headers (in order: h4, h3, h2, h1 to avoid conflicts)
      html = html.replace(/^#### (.+)$/gm, '<h4 id="$1">$1</h4>');
      html = html.replace(/^### (.+)$/gm, '<h3 id="$1">$1</h3>');
      html = html.replace(/^## (.+)$/gm, '<h2 id="$1">$1</h2>');
      html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');

      // hr
      html = html.replace(/^---$/gm, '<hr>');

      // bold and italic
      html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

      // links
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

      // Restore mermaid blocks
      mermaidBlocks.forEach((_, i) => {
        html = html.replace(
          `%%MERMAID_${i}%%`,
          `<div class="mermaid">${escapeHtml(mermaidBlocks[i])}</div>`
        );
      });

      // Tables - collect all table rows first
      const tableRows = [];
      html = html.replace(/^\|(.+)\|$/gm, (match, rowContent) => {
        const cells = rowContent.split('|').map(c => c.trim());
        if (cells.every(c => c.match(/^-+$/))) return '';
        const isTh = !match.includes('</tr>');
        const tag = isTh ? 'th' : 'td';
        tableRows.push('<tr>' + cells.map(c => `<${tag}>${c}</${tag}>`).join('') + '</tr>');
        return '';
      });
      if (tableRows.length > 0) {
        html = html.replace(/%%TABLE%%/g, '<table>' + tableRows.join('') + '</table>');
        // Find table markers and replace with placeholder
        const lines = html.split('\n');
        const result = [];
        let capturing = false;
        let captured = [];
        let inPre = false;
        let inMermaid = false;

        for (let i = 0; i < lines.length; i++) {
          const line = lines[i];
          if (line.includes('<pre>') || line.includes('<div class="mermaid"')) inPre = true;
          if (line.includes('</pre>')) { inPre = false; result.push(line); continue; }
          if (line.includes('</div>') && line.includes('mermaid')) { inMermaid = false; result.push(line); continue; }
          if (inPre || inMermaid) { result.push(line); continue; }

          if (line.trim().startsWith('|') && !capturing) {
            capturing = true;
            captured = [line];
          } else if (line.trim().startsWith('|') && capturing) {
            captured.push(line);
          } else if (capturing) {
            const tableHtml = '<table>' + captured.map(row => {
              const cells = row.split('|').map(c => c.trim());
              if (cells.every(c => c.match(/^-+$/))) return '';
              const isTh = row === captured[0];
              const tag = isTh ? 'th' : 'td';
              return '<tr>' + cells.map(c => `<${tag}>${c}</${tag}>`).join('') + '</tr>';
            }).join('') + '</table>';
            result.push(tableHtml);
            capturing = false;
            captured = [];
            result.push(line);
          } else {
            result.push(line);
          }
        }
        html = result.join('\n');
      }

      // Paragraphs and line breaks
      const lines = html.split('\n');
      const result = [];
      let inBlock = false;
      let blockTags = ['<pre>', '<table>', '<ul>', '<ol>', '<h', '<hr', '<div'];

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const trimmed = line.trim();

        if (!trimmed) { result.push(''); inBlock = false; continue; }

        const isBlockStart = blockTags.some(t => trimmed.startsWith(t));
        const isBlockEnd = trimmed.startsWith('</');

        if (isBlockStart || inBlock) {
          inBlock = true;
          result.push(line);
          if (isBlockEnd && !trimmed.startsWith('<div')) inBlock = false;
          continue;
        }

        if (trimmed.match(/^<(h[1-4]|p|table|ul|ol|li|blockquote|pre|div|hr)/)) {
          result.push(line);
        } else if (trimmed) {
          result.push(`<p>${line}</p>`);
        }
      }

      return result.join('\n');
    }

    const parsed = parseMarkdown(content);
    document.getElementById('content').innerHTML = parsed;

    // Build TOC
    const headings = document.querySelectorAll('#content h2, #content h3, #content h4');
    const tocList = document.querySelector('#table-of-contents ul');
    if (headings.length > 0 && tocList) {
      headings.forEach(h => {
        if (!h.id) h.id = h.textContent;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
      });
    }

    // Initialize mermaid after the markdown has been injected into the DOM.
    (async () => {
      mermaid.initialize({
        startOnLoad: false,
        theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'base',
        flowchart: { curve: 'basis' }
      });

      const mermaidNodes = Array.from(document.querySelectorAll('.mermaid'));
      for (const [index, node] of mermaidNodes.entries()) {
        const code = node.textContent?.trim();
        if (!code) continue;

        try {
          const { svg } = await mermaid.render(`mermaid-${index}`, code);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-pan-wrapper';
          wrapper.style.overflow = 'hidden';
          wrapper.style.position = 'relative';
          node.innerHTML = '';
          node.appendChild(wrapper);
          wrapper.innerHTML = svg;
          const svgEl = wrapper.querySelector('svg');
          console.log('DEBUG: wrapper children:', wrapper.children.length, 'svgEl:', !!svgEl);
          if (svgEl) {
            svgEl.style.overflow = 'visible';
            panzoom(svgEl, {
              maxZoom: 5,
              minZoom: 0.3,
              bounds: true,
              boundsPadding: 0.1,
              zoomDoubleClickSpeed: 1,
            });
            svgEl.style.cursor = 'grab';
            svgEl.addEventListener('mousedown', () => { svgEl.style.cursor = 'grabbing'; });
            svgEl.addEventListener('mouseup', () => { svgEl.style.cursor = 'grab'; });
          }
        } catch (error) {
          node.innerHTML = `<pre>${escapeHtml(error?.message || String(error))}</pre>`;
        }
      }
    })();
  </script>
</body>
</html>
