---

import { execSync, execFileSync } from "node:child_process";
import fs, { existsSync, mkdirSync } from "node:fs";
import path from "node:path";
import https from "node:https";
import http from "node:http";
import MarkdownRenderer from "../components/MarkdownRenderer";
import "./styles.css";

const PLANTUML_JAR = "/tmp/plantuml.jar";

async function downloadFile(url, dest) {
	return new Promise((resolve, reject) => {
		const file = fs.createWriteStream(dest);
		const protocol = url.startsWith("https") ? https : http;
		const req = protocol.get(url, (res) => {
			if (res.statusCode === 302 || res.statusCode === 301) {
				file.close();
				downloadFile(res.headers.location, dest).then(resolve).catch(reject);
				return;
			}
			if (res.statusCode !== 200) { file.close(); reject(new Error(`HTTP ${res.statusCode}`)); return; }
			res.pipe(file);
			file.on("finish", () => { file.close(); resolve(); });
		});
		req.on("error", (e) => { file.close(); reject(e); });
		req.setTimeout(30000, () => { req.destroy(); file.close(); reject(new Error("timeout")); });
	});
}

async function ensurePlantUML() {
	if (existsSync(PLANTUML_JAR)) return;
	try { execSync("plantuml -version", { stdio: "pipe" }); return; } catch {}
	const version = process.env.PLANTUML_VERSION ?? "1.2024.2";
	const jarName = `plantuml-${version}.jar`;
	const url = `https://github.com/plantuml/plantuml/releases/download/v${version}/${jarName}`;
	console.log(`Downloading PlantUML ${version}...`);
	await downloadFile(url, PLANTUML_JAR);
	console.log(`PlantUML JAR saved to ${PLANTUML_JAR}`);
}

function runPlantUML(pumlFile: string, outputDir: string) {
	try {
		execFileSync("java", ["-jar", PLANTUML_JAR, "-tsvg", "-o", outputDir, pumlFile], { stdio: "pipe" });
	} catch {
		try {
			execSync(`plantuml -tsvg -o "${outputDir}" "${pumlFile}"`, { stdio: "pipe" });
		} catch (e) { throw e; }
	}
}

const filePath = path.join(process.cwd(), "public/Trabalho-MSES.md");
const content = fs.readFileSync(filePath, "utf-8");

const diagramsDir = path.join(process.cwd(), "public/diagrams");
if (!existsSync(diagramsDir)) mkdirSync(diagramsDir, { recursive: true });

const plantumlBlocks: string[] = [];
const plantumlSvgPaths: (string | null)[] = [];
const regex = /```plantuml\n([\s\S]*?)\n```/g;
let match;
while ((match = regex.exec(content)) !== null) {
	plantumlBlocks.push(match[1].trim());
}

await ensurePlantUML();

for (let i = 0; i < plantumlBlocks.length; i++) {
	const pumlFile = `/tmp/diagram_${i}.puml`;
	fs.writeFileSync(pumlFile, plantumlBlocks[i]);
	try {
		runPlantUML(pumlFile, diagramsDir);
		const generated = path.join(diagramsDir, `diagram_${i}.svg`);
		if (existsSync(generated) && fs.statSync(generated).size > 100) {
			plantumlSvgPaths.push(`/diagrams/diagram_${i}.svg`);
		} else {
			plantumlSvgPaths.push(null);
		}
	} catch {
		plantumlSvgPaths.push(null);
	}
}
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema de Gestão para Ginásio — MSES</title>
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/panzoom@9.4.3/dist/panzoom.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --bg: #fafafa;
      --bg-code: #1e1e1e;
      --text: #222;
      --text-muted: #666;
      --accent: #3b82f6;
      --border: #e5e5e5;
      --radius: 8px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111;
        --bg-code: #0d0d0d;
        --text: #e5e5e5;
        --text-muted: #888;
        --border: #2a2a2a;
      }
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    h1 {
      font-size: 2em;
      font-weight: 700;
      text-align: left;
      margin-bottom: 1.5em;
      page-break-after: avoid;
    }

    h2 {
      font-size: 1.25em;
      font-weight: 600;
      text-align: left;
      margin-bottom: 1em;
      margin-top: 2.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
      page-break-after: auto;
    }

    h3 {
      font-size: 1em;
      font-weight: 600;
      margin-bottom: 0.875em;
      margin-top: 2rem;
    }

    h4 {
      font-size: 0.85em;
      font-weight: 600;
      margin-bottom: 0.85em;
    }

    p { margin: 0 0 1rem; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    strong { font-weight: 600; }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1.5rem 0;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 0.6rem 0.85rem;
      text-align: left;
    }

    th {
      background: rgba(59, 130, 246, 0.06);
      font-weight: 600;
    }

    @media (prefers-color-scheme: dark) {
      th { background: rgba(59, 130, 246, 0.1); }
    }

    code {
      font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--bg-code);
      color: #e5e5e5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
    }

    pre {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background: none;
      padding: 0;
      font-size: 0.85rem;
    }

    ul, ol {
      padding-left: 1.5rem;
      margin: 0 0 1rem;
    }

    li { margin-bottom: 0.3rem; }

    blockquote {
      border-left: 3px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1rem;
      color: var(--text-muted);
    }

    .mermaid {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin: 2rem 0;
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .mermaid svg {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      cursor: grab;
      overflow: hidden;
    }

    .mermaid svg:active { cursor: grabbing; }

    .mermaid svg > g { pointer-events: all; }

    .mermaid-pan-wrapper {
      overflow: hidden;
      position: relative;
    }

    #table-of-contents {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
    }

    #table-of-contents summary {
      font-weight: 700;
      cursor: pointer;
      margin-bottom: 0.5rem;
      color: var(--text-muted);
      list-style: none;
    }

    #table-of-contents summary::-webkit-details-marker { display: none; }

    #table-of-contents ul {
      list-style: none;
      padding-left: 0;
      margin: 0;
    }

    #table-of-contents li { margin-bottom: 0.25rem; }
    #table-of-contents a { color: var(--text); }
    #table-of-contents a:hover { color: var(--accent); }

    .diagram-fullscreen {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(255, 255, 255, 0.98);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .diagram-fullscreen-backdrop {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.98);
      cursor: pointer;
    }

    .diagram-fullscreen-content {
      position: relative;
      z-index: 1;
      width: 100vw;
      height: 100vh;
    }

    .diagram-fullscreen-content svg,
    .diagram-fullscreen-content img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      cursor: grab;
      overflow: visible;
    }

    .diagram-fullscreen-content svg:active,
    .diagram-fullscreen-content img:active {
      cursor: grabbing;
    }

    .requirement-section {
      margin: 2.5rem 0;
      padding: 1.5rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    @media (prefers-color-scheme: dark) {
      .requirement-section {
        background: rgba(59, 130, 246, 0.04);
      }
    }

    .diagram-fullscreen-hint {
      position: absolute;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.875rem;
      pointer-events: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Sistema de Gestão para Ginásio</h1>
      <p style="color:var(--text-muted); margin:0">Modelação de Sistemas e Engenharia de Software — Universidade de Aveiro</p>
    </header>

    <MarkdownRenderer content={content} plantumlSvgPaths={plantumlSvgPaths} client:load />
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/panzoom@9.4.3/dist/panzoom.min.js"></script>
</body>
</html>
