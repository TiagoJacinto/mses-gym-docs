---
import fs from 'node:fs';
import path from 'node:path';
import { execSync } from 'node:child_process';
import { mkdirSync, existsSync } from 'node:fs';

const filePath = path.join(process.cwd(), 'public/Trabalho-MSES.md');
const content = fs.readFileSync(filePath, 'utf-8');

const diagramsDir = path.join(process.cwd(), 'public/diagrams');
if (!existsSync(diagramsDir)) mkdirSync(diagramsDir, { recursive: true });

const plantumlBlocks = [];
const plantumlSvgPaths = [];
const regex = /```plantuml\n([\s\S]*?)\n```/g;
let match;
while ((match = regex.exec(content)) !== null) {
  plantumlBlocks.push(match[1].trim());
}

for (let i = 0; i < plantumlBlocks.length; i++) {
  const pumlFile = `/tmp/diagram_${i}.puml`;
  const svgFile = path.join(diagramsDir, `diagram_${i}.svg`);
  fs.writeFileSync(pumlFile, plantumlBlocks[i]);
  try {
    execSync(`plantuml -tsvg -o "${diagramsDir}" "${pumlFile}" 2>/dev/null`, { stdio: 'pipe' });
    const generated = path.join(diagramsDir, `diagram_${i}.svg`);
    if (existsSync(generated) && fs.statSync(generated).size > 100) {
      plantumlSvgPaths.push(`/diagrams/diagram_${i}.svg`);
    } else {
      plantumlSvgPaths.push(null);
    }
  } catch {
    plantumlSvgPaths.push(null);
  }
}

export const prerender = true;
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema de Gestão para Ginásio — MSES</title>
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/panzoom@9.4.3/dist/panzoom.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --bg: #fafafa;
      --bg-code: #1e1e1e;
      --text: #222;
      --text-muted: #666;
      --accent: #3b82f6;
      --border: #e5e5e5;
      --radius: 8px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111;
        --bg-code: #0d0d0d;
        --text: #e5e5e5;
        --text-muted: #888;
        --border: #2a2a2a;
      }
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    h1 {
      font-size: 2rem;
      font-weight: 800;
      margin: 0 0 0.5rem;
      letter-spacing: -0.03em;
    }

    h2 {
      font-size: 1.4rem;
      font-weight: 700;
      margin: 2.5rem 0 1rem;
      letter-spacing: -0.02em;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
    }

    h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
    }

    h4 {
      font-size: 1rem;
      font-weight: 600;
      margin: 1.5rem 0 0.5rem;
    }

    p { margin: 0 0 1rem; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    strong { font-weight: 600; }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1.5rem 0;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 0.6rem 0.85rem;
      text-align: left;
    }

    th {
      background: rgba(59, 130, 246, 0.06);
      font-weight: 600;
    }

    @media (prefers-color-scheme: dark) {
      th { background: rgba(59, 130, 246, 0.1); }
    }

    code {
      font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--bg-code);
      color: #e5e5e5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
    }

    pre {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background: none;
      padding: 0;
      font-size: 0.85rem;
    }

    ul, ol {
      padding-left: 1.5rem;
      margin: 0 0 1rem;
    }

    li { margin-bottom: 0.3rem; }

    blockquote {
      border-left: 3px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1rem;
      color: var(--text-muted);
    }

    .mermaid {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin: 2rem 0;
      text-align: center;
      overflow: hidden;
      position: relative;
    }

    .mermaid svg {
      display: block;
      margin: 0 auto;
      max-width: 100%;
      cursor: grab;
      overflow: hidden;
    }

    .mermaid svg:active { cursor: grabbing; }

    .mermaid svg > g { pointer-events: all; }

    .mermaid-pan-wrapper {
      overflow: hidden;
      position: relative;
    }

    #table-of-contents {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
    }

    #table-of-contents summary {
      font-weight: 700;
      cursor: pointer;
      margin-bottom: 0.5rem;
      color: var(--text-muted);
      list-style: none;
    }

    #table-of-contents summary::-webkit-details-marker { display: none; }

    #table-of-contents ul {
      list-style: none;
      padding-left: 0;
      margin: 0;
    }

    #table-of-contents li { margin-bottom: 0.25rem; }
    #table-of-contents a { color: var(--text); }
    #table-of-contents a:hover { color: var(--accent); }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Sistema de Gestão para Ginásio</h1>
      <p style="color:var(--text-muted); margin:0">Modelação de Sistemas e Engenharia de Software — Universidade de Aveiro</p>
    </header>

    <details id="table-of-contents" open>
      <summary>Índice</summary>
      <ul></ul>
    </details>

    <article id="content"></article>
  </div>

  <script is:inline define:vars={{ content, plantumlSvgPaths }}>
    function escapeHtml(text) {
      return text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function parseMarkdown(md) {
      let html = md;

      // mermaid code blocks - extract before processing
      const mermaidBlocks = [];
      html = html.replace(/```mermaid\n([\s\S]*?)```/g, (_, code) => {
        mermaidBlocks.push(code.trim());
        return `%%MERMAID_${mermaidBlocks.length - 1}%%`;
      });

      // plantuml code blocks - extract before processing
      const plantumlBlocks = [];
      html = html.replace(/```plantuml\n([\s\S]*?)```/g, (_, code) => {
        plantumlBlocks.push(code.trim());
        return `%%PLANTUML_${plantumlBlocks.length - 1}%%`;
      });

      // inline code
      html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

      // headers (in order: h4, h3, h2, h1 to avoid conflicts)
      html = html.replace(/^#### (.+)$/gm, '<h4 id="$1">$1</h4>');
      html = html.replace(/^### (.+)$/gm, '<h3 id="$1">$1</h3>');
      html = html.replace(/^## (.+)$/gm, '<h2 id="$1">$1</h2>');
      html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');

      // hr
      html = html.replace(/^---$/gm, '<hr>');

      // bold and italic
      html = html.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
      html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');

      // links
      html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');

      // Restore mermaid blocks
      mermaidBlocks.forEach((_, i) => {
        html = html.replace(
          `%%MERMAID_${i}%%`,
          `<div class="mermaid">${escapeHtml(mermaidBlocks[i])}</div>`
        );
      });

      // Restore plantuml blocks
      plantumlBlocks.forEach((_, i) => {
        html = html.replace(
          `%%PLANTUML_${i}%%`,
          `<div class="plantuml">${escapeHtml(plantumlBlocks[i])}</div>`
        );
      });

      // Tables - group consecutive pipe lines into tables
      const lines = html.split('\n');
      const resultLines = [];
      let i = 0;
      
      while (i < lines.length) {
        const line = lines[i];
        
        // Check if this line is a table row (starts with |)
        if (line.match(/^\|.*\|$/)) {
          const tableLines = [];
          
          // Collect consecutive table rows
          while (i < lines.length && lines[i].match(/^\|.*\|$/)) {
            tableLines.push(lines[i]);
            i++;
          }
          
          // Process the table
          if (tableLines.length > 0) {
            const rows = [];
            let headerProcessed = false;
            
            for (const tableLine of tableLines) {
              const cells = tableLine.split('|').map(c => c.trim()).filter(c => c.length > 0 && !c.match(/^-+$/));
              if (cells.length === 0) continue;
              
              const tag = headerProcessed ? 'td' : 'th';
              const rowHtml = '<tr>' + cells.map(c => `<${tag} style="border: 1px solid #333;">${c}</${tag}>`).join('') + '</tr>';
              rows.push(rowHtml);
              headerProcessed = true;
            }
            
            if (rows.length > 0) {
              resultLines.push('<table style="border-collapse: collapse;" data-astro-cid-j7pv25f6><tbody>' + rows.join('') + '</tbody></table>');
            }
          }
        } else {
          resultLines.push(line);
          i++;
        }
      }
      
      html = resultLines.join('\n');

      // Paragraphs and line breaks
      const allLines = html.split('\n');
      const result = [];
      let inBlock = false;
      let blockTags = ['<pre>', '<table>', '<ul>', '<ol>', '<h', '<hr', '<div'];

      for (let i = 0; i < allLines.length; i++) {
        const line = allLines[i];
        const trimmed = line.trim();

        if (!trimmed) { result.push(''); inBlock = false; continue; }

        const isBlockStart = blockTags.some(t => trimmed.startsWith(t));
        const isBlockEnd = trimmed.startsWith('</');

        if (isBlockStart || inBlock) {
          inBlock = true;
          result.push(line);
          if (isBlockEnd && !trimmed.startsWith('<div')) inBlock = false;
          continue;
        }

        if (trimmed.match(/^<(h[1-4]|p|table|ul|ol|li|blockquote|pre|div|hr)/)) {
          result.push(line);
        } else if (trimmed) {
          result.push(`<p>${line}</p>`);
        }
      }

      return result.join('\n');
    }

    const parsed = parseMarkdown(content);
    document.getElementById('content').innerHTML = parsed;

    // Build TOC
    const headings = document.querySelectorAll('#content h2, #content h3, #content h4');
    const tocList = document.querySelector('#table-of-contents ul');
    if (headings.length > 0 && tocList) {
      headings.forEach(h => {
        if (!h.id) h.id = h.textContent;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
      });
    }

    // Initialize mermaid after the markdown has been injected into the DOM.
    (async () => {
      mermaid.initialize({
        startOnLoad: false,
        theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'base',
        flowchart: { curve: 'basis' }
      });

      const mermaidNodes = Array.from(document.querySelectorAll('.mermaid'));
      for (const [index, node] of mermaidNodes.entries()) {
        const code = node.textContent?.trim();
        if (!code) continue;

        try {
          const { svg } = await mermaid.render(`mermaid-${index}`, code);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-pan-wrapper';
          wrapper.style.overflow = 'hidden';
          wrapper.style.position = 'relative';
          node.innerHTML = '';
          node.appendChild(wrapper);
          wrapper.innerHTML = svg;
          const svgEl = wrapper.querySelector('svg');
          console.log('DEBUG: wrapper children:', wrapper.children.length, 'svgEl:', !!svgEl);
          if (svgEl) {
            svgEl.style.overflow = 'visible';
            panzoom(svgEl, {
              maxZoom: 5,
              minZoom: 0.3,
              bounds: true,
              boundsPadding: 0.1,
              zoomDoubleClickSpeed: 1,
            });
            svgEl.style.cursor = 'grab';
            svgEl.addEventListener('mousedown', () => { svgEl.style.cursor = 'grabbing'; });
            svgEl.addEventListener('mouseup', () => { svgEl.style.cursor = 'grab'; });
          }
        } catch (error) {
          node.innerHTML = `<pre>${escapeHtml(error?.message || String(error))}</pre>`;
        }
      }
    // Initialize PlantUML diagrams from pre-rendered static SVGs
      const plantumlNodes = Array.from(document.querySelectorAll('.plantuml'));
      plantumlNodes.forEach((node, index) => {
        const svgPath = plantumlSvgPaths[index];
        if (!svgPath) return;

        node.innerHTML = '';
        const wrapper = document.createElement('div');
        wrapper.className = 'plantuml-pan-wrapper';
        wrapper.style.overflow = 'hidden';
        wrapper.style.position = 'relative';
        node.appendChild(wrapper);

        const img = document.createElement('img');
        img.src = svgPath;
        img.alt = 'PlantUML diagram';
        img.style.maxWidth = '100%';
        img.style.display = 'block';
        img.style.margin = '0 auto';
        img.style.cursor = 'grab';
        wrapper.appendChild(img);

        img.onload = () => {
          panzoom(img, {
            maxZoom: 5,
            minZoom: 0.3,
            bounds: true,
            boundsPadding: 0.1,
            zoomDoubleClickSpeed: 1,
          });
          img.addEventListener('mousedown', () => { img.style.cursor = 'grabbing'; });
          img.addEventListener('mouseup', () => { img.style.cursor = 'grab'; });
        };
        img.onerror = () => {
          wrapper.innerHTML = `<pre>Failed to load ${svgPath}</pre>`;
        };
      });
    })();
  </script>
</body>
</html>
