---
import "./github-markdown.css";
import TrabalhoMSES from "../../public/Trabalho-MSES.md";
---

<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema de Gestão para Ginásio — MSES</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --bg: #fafafa;
      --bg-code: #1e1e1e;
      --text: #222;
      --text-muted: #666;
      --accent: #3b82f6;
      --border: #e5e5e5;
      --radius: 8px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111;
        --bg-code: #0d0d0d;
        --text: #e5e5e5;
        --text-muted: #888;
        --border: #2a2a2a;
      }
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .cover {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 5rem 2rem 4rem;
    }

    .cover-eyebrow {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .cover h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
      color: var(--text);
    }

    .cover-subtitle {
      font-size: 1rem;
      color: var(--text-muted);
      margin-bottom: 2.5rem;
      max-width: 50ch;
      line-height: 1.6;
    }

    .cover-divider {
      width: 50px;
      height: 2px;
      background: var(--border);
      border-radius: 2px;
      margin-bottom: 2.5rem;
    }

    .cover-authors {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      font-size: 0.875rem;
      color: var(--text-muted);
      text-align: center;
    }

    .cover-authors li { margin-bottom: 0.25rem; }
    .cover-authors strong { color: var(--text); font-weight: 600; }

    .cover-course {
      font-size: 0.875rem;
      color: var(--text-muted);
      font-style: italic;
      margin-bottom: 0.5rem;
    }

    .cover-advisor {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .cover-date {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    @media (max-width: 600px) {
      .cover-meta {
        grid-template-columns: 1fr;
        gap: 0.5rem;
      }
    }

    h2 {
      font-size: 1.25em;
      font-weight: 600;
      text-align: left;
      margin-bottom: 1em;
      margin-top: 2.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
      page-break-after: auto;
    }

    h3 {
      font-size: 1em;
      font-weight: 600;
      margin-bottom: 0.875em;
      margin-top: 2rem;
    }

    h4 {
      font-size: 0.85em;
      font-weight: 600;
      margin-bottom: 0.85em;
    }

    p { margin: 0 0 1rem; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    strong { font-weight: 600; }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1em 0;
      border: 4px solid #333;
    }

    th, td {
      border: 4px solid #333;
      padding: 0.5em 1em;
      text-align: left;
    }

    th {
      background: rgba(59, 130, 246, 0.06);
      font-weight: 600;
    }

    @media (prefers-color-scheme: dark) {
      th { background: rgba(59, 130, 246, 0.1); }
    }

    .markdown-body table.striped tr:nth-child(even) { background-color: #f6f8fa; }
    .markdown-body table.bordered { border: 2px solid #333; }
    .markdown-body table.minimal { border-collapse: collapse; border-width: 1px; }
    .markdown-body table.compact { font-size: 0.9em; }

    code {
      font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
      font-size: 0.875em;
      background: var(--bg-code);
      color: #e5e5e5;
      padding: 0.15em 0.4em;
      border-radius: 4px;
    }

    body pre.mermaid {
      padding: 1.25rem !important;
    }

    pre {
      background: var(--bg-code);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background: none;
      padding: 0;
      font-size: 0.85rem;
    }

    ul, ol {
      padding-left: 1.5rem;
      margin: 0 0 1rem;
    }

    li { margin-bottom: 0.3rem; }

    blockquote {
      border-left: 3px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1rem;
      color: var(--text-muted);
    }

    #table-of-contents {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      font-size: 0.9rem;
    }

    #table-of-contents h2 {
      margin-top: 0;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      font-size: 1.1rem;
    }

    #table-of-contents ol, #table-of-contents ul {
      list-style: none;
      padding-left: 0;
      margin: 0;
    }

    #table-of-contents li {
      margin-bottom: 0.35rem;
    }

    #table-of-contents li li {
      margin-bottom: 0.25rem;
      margin-left: 1.25rem;
    }

    #table-of-contents li li li {
      margin-left: 2.5rem;
      font-size: 0.85rem;
    }

    #table-of-contents a {
      color: var(--text);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    #table-of-contents a:hover {
      color: var(--accent);
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="cover">
      <p class="cover-eyebrow">Modelação de Sistemas e Engenharia de Software</p>
      <h1>Sistema de Gestão<br>para Ginásio</h1>
      <div class="cover-divider"></div>
      <ul class="cover-authors">
        <li>Derlan Nascimento · nº mec. 129942</li>
        <li>Micael Oliveira · nº mec. 131700</li>
        <li>Rodrigo Fonseca · nº mec. 131619</li>
        <li>Tiago Jacinto · nº mec. 131339</li>
      </ul>
      <p class="cover-course">Programação de Sistema de Informação — Universidade de Aveiro</p>
      <p class="cover-advisor">Orientador: Professor José Martins</p>
      <p class="cover-date">Águeda, 25 de março de 2026</p>
    </header>

    <article class="markdown-body">
      <TrabalhoMSES />
    </article>
  </div>
</body>
</html>